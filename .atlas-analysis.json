  "keyFeatures": [
    "M3U/M3U8 and Xtream Codes playlist ingestion and transformation",
    "Reverse proxy and redirect modes for live IPTV streams",
    "Advanced filtering with expressive boolean/regex DSL",
    "Multi-source merging and custom target publishing",
    "HDHomeRun emulation for Plex, Emby, Jellyfin and TVHeadend",
    "Local media library scanning with TMDB metadata enrichment",
    "Scheduled playlist updates with cron expressions",
    "Multi-user access control with per-target credentials",
    "Stream sharing, priority preemption and custom fallback videos",
    "Notifications via Telegram, Discord, Pushover and REST webhooks",
    "Web UI with hot config reload support",
    "Docker and static binary deployment"
  ],
  "publicApiSurface": [
    "GET /get.php (M3U playlist endpoint)",
    "GET /xmltv.php (XMLTV/EPG endpoint)",
    "POST /player_api.php (Xtream Codes API)",
    "GET /hdhomerun/* (HDHomeRun emulation endpoints)",
    "GET /hls/* (HLS stream proxy)",
    "GET /v1/* (REST management API)",
    "WS /ws (WebSocket events)",
    "CLI: tuliprox -s (server mode)",
    "CLI: tuliprox -c <config> -i <source> (CLI mode)",
    "CLI: tuliprox --genpwd (password hash generation)",
    "CLI: tuliprox --healthcheck (health probe)",
    "CLI: tuliprox --scan-library (trigger library scan)"
  ]
