{
  "projectType": "saas",
  "projectName": "tuliprox",
  "projectDescription": "A high-performance IPTV proxy and playlist processor written in Rust that ingests M3U/Xtream sources, reshapes and filters them, and delivers streams to Plex, Jellyfin, Emby, Kodi and similar media clients.",
